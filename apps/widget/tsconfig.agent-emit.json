{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "isolatedModules": true,
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist/agent",
    "rootDir": "src/agent",
    "strict": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true
  },
  "include": ["src/agent/**/*"]
}
