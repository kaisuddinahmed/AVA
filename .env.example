# Server
PORT=8080
WS_PORT=8081

# Database
# Local dev (SQLite):
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL) — replace above two lines with:
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://user:password@host:5432/ava?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://user:password@host:5432/ava?sslmode=require"  # if using PgBouncer/Supabase

# LLM (Groq)
GROQ_API_KEY=gsk_xxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# MSWIM Defaults (overridden by ScoringConfig in DB)
MSWIM_W_INTENT=0.25
MSWIM_W_FRICTION=0.25
MSWIM_W_CLARITY=0.15
MSWIM_W_RECEPTIVITY=0.20
MSWIM_W_VALUE=0.15
MSWIM_T_MONITOR=29
MSWIM_T_PASSIVE=49
MSWIM_T_NUDGE=64
MSWIM_T_ACTIVE=79

# Dashboard
VITE_WS_URL=ws://localhost:8081
VITE_API_URL=http://localhost:8080

# Widget (dev)
AVA_DEV_SERVER_URL=ws://localhost:8081

# Voice Interventions (Deepgram TTS/STT — key stays server-side; widget calls /api/voice/tts and /api/voice/sst proxy)
DEEPGRAM_API_KEY=
VOICE_ENABLED=false
VOICE_MAX_PER_SESSION=3

# Evaluation Engine
# Options: llm | fast | auto
# "auto" = fast-first, escalates to LLM when composite >= 65 or max friction severity >= 75
EVAL_ENGINE=auto

# Shadow Mode (replay evaluations without firing interventions)
SHADOW_MODE_ENABLED=false
SHADOW_LOG_CONSOLE=false
